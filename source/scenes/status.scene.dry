{!<span class="tooltip-text" title="The Left are a collection of progressive clerics and trade unionists. They are interested in co-operation with the socialists and defending the Republic.">Left</span>!} strength: [+ left_strength : strength +], dissent: [+ left_dissent : dissent +]

{!<span class="tooltip-text" title="The Center are pragmatists, seeking the defence of catholic interests above all else.">Center</span>!} strength: [+ center_strength : strength +], dissent: [+ center_dissent : dissent +]

{!<span class="tooltip-text" title="The Clerical wing of Zentrum are generally conservative, and seek to defend the church. They are the strongest opponents of leaving the tower.">Clerics</span>!} strength: [+ clerical_strength : strength +], dissent: [+ clerical_dissent : dissent +]

{!<span class="tooltip-text" title="The christian labour movement wants to transform Zentrum into a interconfessional party on the moderate Right">Labor</span>!} strength: [+ labour_strength : strength +], dissent: [+ labour_dissent : dissent +]




@paramilitaries
on-arrival: {!
if (Q.rb_strength) {
    Q.rb_strength_2 = Q.rb_strength.toFixed(1);
}
if (Q.rfb_strength) {
    Q.rfb_strength_2 = Q.rfb_strength.toFixed(1);
}
if (Q.sh_strength) {
    Q.sh_strength_2 = Q.sh_strength.toFixed(1);
}
if (Q.sa_strength) {
    Q.sa_strength_2 = Q.sa_strength.toFixed(1);
}
!}

